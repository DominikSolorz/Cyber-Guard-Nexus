# ========================================
# DOCUMENT MANAGER AI - CONFIGURATION
# ========================================
# INSTRUKCJA: Skopiuj ten plik do .env i wpisz prawdziwe wartości
# Komenda: cp .env.example .env

# ========================================
# OPENAI API
# ========================================
# Pobierz z: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/document_manager

# ========================================
# JWT SECRET (wygeneruj losowy string)
# ========================================
# Przykład generowania: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# GMAIL INTEGRATION
# ========================================
# Email: twój adres Gmail
GMAIL_EMAIL=your-email@gmail.com

# App Password: wygeneruj w https://myaccount.google.com/apppasswords
# Format: xxxx xxxx xxxx xxxx (16 znaków)
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# SMTP/IMAP Settings (domyślne dla Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ========================================
# APPLICATION SETTINGS
# ========================================
APP_NAME=Document Manager AI
APP_VERSION=1.0.0
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5120
